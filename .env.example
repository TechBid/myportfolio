# Environment Variables for Portfolio Admin Panel

# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production

# Admin Authentication
ADMIN_PASSWORD_HASH=your-hashed-password-here

# GitHub API Configuration (for production deployment)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_REPO=SHIVOGOJOHN/Profile
GITHUB_BRANCH=main

# Operation Mode
# Set to 'true' to use GitHub API, 'false' for local file operations
USE_GITHUB_API=false

# IMPORTANT: Add this file to .gitignore to prevent committing secrets!
